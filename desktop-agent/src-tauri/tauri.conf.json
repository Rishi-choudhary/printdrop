{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri-schema/main/schema.json",
  "productName": "PrintDrop Agent",
  "version": "1.0.0",
  "identifier": "com.printdrop.agent",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "windows": [
      {
        "title": "PrintDrop Agent",
        "width": 480,
        "height": 640,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "plugins": {
    "autostart": {
      "macosExtraArgs": ["--flag1", "--flag2"],
      "args": ["--autostart"]
    },
    "notification": {
      "enabled": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
