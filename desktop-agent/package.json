{
  "name": "printdrop-agent",
  "version": "1.0.0",
  "description": "PrintDrop Desktop Print Agent",
  "main": "main.js",
  "author": {
    "name": "PrintDrop",
    "email": "hello@printdrop.app",
    "url": "https://printdrop.app"
  },
  "homepage": "https://printdrop.app",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder -mwl",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:universal": "electron-builder --mac --x64 --arm64",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always",
    "release:draft": "electron-builder --publish onTagOrDraft",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "electron-updater": "^6.2.1",
    "pdf-lib": "^1.17.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  }
}
