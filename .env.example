# ============================================
# PrintDrop Environment Configuration
# Copy this file to .env and fill in values
# ============================================

# ---- Database (Supabase Postgres) ----
# Get from: Supabase Dashboard > Project Settings > Database
# Transaction pooler (port 6543) for app connections:
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) for migrations:
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# ---- Server ----
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:3001

# ---- Authentication ----
JWT_SECRET=your-super-secret-jwt-key-change-this
# Set to 1 only for local setup when you need seed scripts to print generated PINs/agent keys.
PRINTDROP_SHOW_SEED_CREDENTIALS=0

# ---- Cloudflare R2 (File Storage) ----
# Get from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=printdrop
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
# "local" = local filesystem, "r2" = Cloudflare R2
STORAGE_DRIVER=local

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/api/webhooks/telegram

# ---- WhatsApp (Gupshup) ----
# Primary messaging channel. Get credentials from: app.gupshup.io > Dashboard > API
#
# API Key — shown on the Gupshup dashboard (long hex string)
WHATSAPP_API_KEY=your-gupshup-api-key
# Gupshup send endpoint — do not change unless Gupshup updates their API
WHATSAPP_API_URL=https://api.gupshup.io/wa/api/v1/msg
# Your WhatsApp number registered on Gupshup — digits only, no + (e.g. 918291234567)
GUPSHUP_SOURCE_NUMBER=91XXXXXXXXXX
# App/bot name as registered in the Gupshup dashboard (shown to users)
GUPSHUP_APP_NAME=PrintDrop
# Gupshup webhook URL to configure in Gupshup dashboard:
#   https://YOUR_DOMAIN/api/webhooks/whatsapp
# Optional webhook token — set this in Gupshup Callback > Header Token for basic auth.
# The same value must be set in the x-gupshup-token header in Gupshup settings.
WHATSAPP_WEBHOOK_SECRET=your-webhook-token
# WhatsApp number to show users on the payment success page (digits only, no +)
# e.g. NEXT_PUBLIC_WHATSAPP_NUMBER=918291234567
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# ---- WhatsApp Template Messages (Gupshup HSM) ----
# Required for business-initiated messages that may land outside the 24-hour
# session window (e.g. token sent by the Razorpay webhook minutes after user paid).
#
# Create these in Gupshup Dashboard → Templates → New Template.
# Category: UTILITY   Language: English (en)
#
# Template 1 — order confirmed + token issued
#   Suggested name: printdrop_token_issued
#   Body text: "Your PrintDrop order is confirmed! Token: #{{1}}. Pick up at {{2}}."
#   Variables: {{1}} = token number (e.g. 042), {{2}} = shop name
GUPSHUP_TEMPLATE_TOKEN_ISSUED=printdrop_token_issued
#
# Template 2 — print ready for pickup
#   Suggested name: printdrop_ready_for_pickup
#   Body text: "Your print is ready! Token: #{{1}}. Pick up at {{2}}."
#   Variables: {{1}} = token number, {{2}} = shop name
GUPSHUP_TEMPLATE_READY_FOR_PICKUP=printdrop_ready_for_pickup
#
# If templates are not yet approved, leave these blank — the system falls back to
# regular freeform messages (works within the 24h session window only).

# ---- Bot Configuration ----
# Set BOT_V2=1 to enable the experimental lean 3-state WhatsApp flow (no OTP).
# Leave unset or BOT_V2=0 to use the production legacy DB-backed flow (RECOMMENDED).
# WARNING: v2 uses in-memory sessions (lost on restart) and drops custom page range,
#          paper size, sides selection, and multi-shop selection — NOT for production.
# BOT_V2=0

# ---- Razorpay ----
# Get from: Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
# Webhook secret — get/set from: Razorpay Dashboard > Settings > Webhooks
# Configure webhook URL in Razorpay to: https://YOUR_DOMAIN/api/webhooks/razorpay
# Events to subscribe: payment_link.paid, payment.captured, payment.failed,
#                      payment_link.expired, payment_link.cancelled
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ---- File Upload ----
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx,ppt,pptx

# ---- LibreOffice (Doc Conversion) ----
LIBREOFFICE_URL=http://localhost:3002

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Admin ----
ADMIN_PHONE=+919999999999
